# MongoDB Connection
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/nota?retryWrites=true&w=majority

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_here_min_64_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_64_chars

# JWT Expiry
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# Anthropic (for server-side AI calls)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# CORS - your Vercel frontend URL
FRONTEND_URL=https://your-app.vercel.app
